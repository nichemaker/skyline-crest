---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Localities from '../components/Localities.astro';
import Properties from '../components/Properties.astro';
import DeveloperMarquee from '../components/DeveloperMarquee.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateAgent",
  "name": "Skyline Crest Realty",
  "url": "https://www.skylinecrest.co.in",
  "logo": "https://www.skylinecrest.co.in/favicon.svg",
  "description": "A boutique, client-first real estate consultancy for luxury and premium property across Gurugram. Advisory-led guidance for discerning buyers and investors.",
  "telephone": "+918800654747",
  "email": "hello@skylinecrest.co.in",
  "foundingDate": "2008",
  "areaServed": "Gurugram",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Tower B, Golf Course Road, Sector 42",
    "addressLocality": "Gurugram",
    "addressRegion": "Haryana",
    "postalCode": "122002",
    "addressCountry": "IN"
  },
  "openingHours": "Mo-Sa 10:00-19:00"
};
---
<Layout
  title="Skyline Crest Realty — Gurgaon's Trusted Luxury Real Estate Consultant"
  description="Advisory-led guidance for discerning buyers and investors across Gurugram — builder floors, villas, plots and commercial assets. Est. 2008. RERA registered."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <div id="site-root" data-theme="light" style="font-family:'Hanken Grotesk',-apple-system,system-ui,sans-serif;background:var(--bg);color:var(--ink);min-height:100vh;overflow-x:hidden;position:relative;transition:background .4s ease,color .4s ease;">
    <Header />
    <main>
      <Hero />
      <Stats />
      <About />
      <Services />
      <Localities />
      <Properties />
      <DeveloperMarquee />
      <Testimonials />
      <FAQ />
      <Contact />
    </main>
    <Footer />

    <!-- Floating WhatsApp (desktop) -->
    <a href="https://wa.me/918800654747" class="wa-float" aria-label="Chat on WhatsApp" rel="noopener noreferrer">
      <span class="wa-float-icon"></span>
    </a>

    <!-- Mobile call bar -->
    <div class="mobile-call-bar">
      <a href="tel:+918800654747" class="mcb-call">Call Now</a>
      <a href="https://wa.me/918800654747" class="mcb-wa" rel="noopener noreferrer">WhatsApp</a>
    </div>
  </div>
</Layout>

<script>
  const root      = document.getElementById('site-root')!;
  const header    = document.getElementById('site-header')!;
  const toggle    = document.getElementById('theme-toggle')!;
  const hamburger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const mobileClose = document.getElementById('mobile-close')!;
  const mobileTheme = document.getElementById('mobile-theme')!;

  // --- Header scroll ---
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  // --- Theme ---
  function toggleTheme() {
    const next = root.dataset.theme === 'light' ? 'dark' : 'light';
    root.dataset.theme = next;
  }
  toggle.addEventListener('click', toggleTheme);
  mobileTheme.addEventListener('click', toggleTheme);

  // --- Mobile menu ---
  hamburger.addEventListener('click', () => mobileMenu.classList.add('open'));
  mobileClose.addEventListener('click', () => mobileMenu.classList.remove('open'));
  mobileMenu.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => mobileMenu.classList.remove('open'))
  );


  // --- Counter animation ---
  function runCounter(el: HTMLElement) {
    const target = parseFloat(el.dataset.target!) || 0;
    const suffix = el.dataset.suffix || '';
    const dur = 1500;
    const start = performance.now();
    const tick = (now: number) => {
      const p = Math.min(1, (now - start) / dur);
      const e = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(target * e).toLocaleString('en-IN') + suffix;
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  const statsEl = document.getElementById('stats');
  if (statsEl) {
    const sio = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          document.querySelectorAll<HTMLElement>('[data-counter]').forEach(runCounter);
          sio.disconnect();
        }
      });
    }, { threshold: 0.35 });
    sio.observe(statsEl);
  }

  // --- Gate hero animation to viewport ---
  const heroBg = document.querySelector<HTMLElement>('.hero-bg');
  if (heroBg) {
    const hio = new IntersectionObserver(entries => {
      entries.forEach(e => {
        heroBg.style.animationPlayState = e.isIntersecting ? 'running' : 'paused';
      });
    }, { threshold: 0 });
    hio.observe(document.querySelector('#home') || heroBg);
  }
</script>
