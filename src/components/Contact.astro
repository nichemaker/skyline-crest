---
---
<section id="contact">
  <div class="section-inner">
    <div class="contact-grid">
      <div>
        <div class="section-eyebrow">
          <span class="section-eyebrow-line"></span>
          <span class="section-eyebrow-text">Get in touch</span>
        </div>
        <h2 class="section-h2" style="font-size:clamp(30px,4.4vw,56px);">
          <span style="font-size:.58em;">Let's discuss</span>
          your next property.
        </h2>
        <p class="contact-info-p">
          A 30-minute consultation, no obligation. Tell us where you are in your journey and we'll take it from there.
        </p>
        <div class="contact-links">
          <a href="tel:+918800654747" class="contact-link">
            <span class="contact-link-label">Phone</span>
            <span class="contact-link-value">+91 88006 54747</span>
          </a>
          <a href="mailto:hello@skylinecrest.co.in" class="contact-link">
            <span class="contact-link-label">Email</span>
            <span class="contact-link-value">hello@skylinecrest.co.in</span>
          </a>
          <a href="https://wa.me/918800654747" class="contact-wa-link" rel="noopener noreferrer">
            <span class="contact-wa-label">WhatsApp</span>
            <span class="contact-wa-value">Chat with an advisor</span>
          </a>
        </div>
      </div>

      <div class="contact-form-wrap">
        <div class="contact-success" id="contact-success" style="display:none;">
          <div class="contact-success-icon">✓</div>
          <h3>Thank you.</h3>
          <p>An advisor will reach out within one business day.</p>
        </div>
        <form class="contact-form" id="contact-form" novalidate>
          <div class="contact-form-row">
            <label class="contact-field">
              <span class="contact-field-label">Name</span>
              <input type="text" required placeholder="Your name" />
            </label>
            <label class="contact-field">
              <span class="contact-field-label">Email / Phone</span>
              <input type="text" required placeholder="How to reach you" />
            </label>
          </div>
          <label class="contact-field">
            <span class="contact-field-label">Property Type</span>
            <select>
              <option>Residential — Apartment</option>
              <option>Residential — Builder Floor</option>
              <option>Villa</option>
              <option>Plot</option>
              <option>Commercial / Retail</option>
              <option>Investment Advisory</option>
            </select>
          </label>
          <label class="contact-field">
            <span class="contact-field-label">Message</span>
            <textarea rows="4" placeholder="Budget, preferred areas, timeline…"></textarea>
          </label>
          <button type="submit" class="contact-submit">Request a Consultation</button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('contact-success')!;

  form.addEventListener('submit', e => {
    e.preventDefault();
    form.style.display = 'none';
    success.style.display = '';
  });
</script>
