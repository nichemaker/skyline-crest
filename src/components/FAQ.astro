---
const faqs = [
  {
    q: 'Which Gurgaon areas suit luxury buyers right now?',
    a: "For end-use, DLF Phases, Golf Course Road and Sushant Lok offer mature, low-density living. For appreciation, Golf Course Extension and Dwarka Expressway are the corridors we watch most closely — we'll match the area to whether you're buying to live or to invest.",
  },
  {
    q: 'Do you support NRI buyers end-to-end?',
    a: "Yes. We handle remote viewings, documentation, POA coordination, registry and handover, and stay your single point of contact through the entire process — a large share of our clients are NRIs across the GCC, UK and US.",
  },
  {
    q: "I'm a first-time buyer — can you guide me?",
    a: "Absolutely. We start with an honest conversation about budget, financing and trade-offs before showing a single property, then walk you through every step at your pace — no jargon, no pressure.",
  },
  {
    q: 'What types of property do you handle?',
    a: "Residential apartments and builder floors, independent villas, freehold plots, and commercial and retail assets — plus portfolio and investment advisory for clients building a property portfolio in Gurugram.",
  },
  {
    q: 'How do your advisory fees work?',
    a: "Transparently, and discussed upfront before any engagement. There are no hidden charges and no incentive to push particular inventory — our recommendations are aligned to your interest, not a builder's.",
  },
];
---
<section id="faq">
  <div class="faq-inner">
    <div class="faq-head" data-reveal>
      <div class="section-eyebrow">
        <span class="section-eyebrow-line"></span>
        <span class="section-eyebrow-text">Questions, answered</span>
        <span class="section-eyebrow-line"></span>
      </div>
      <h2 class="section-h2" style="color:var(--ink);font-size:clamp(28px,4vw,48px);">For Gurgaon buyers &amp; investors</h2>
    </div>
    <div class="faq-list">
      {faqs.map((f, i) => (
        <div class="faq-item" id={`faq-${i}`}>
          <button class="faq-btn" aria-expanded="false" aria-controls={`faq-a-${i}`}>
            <span class="faq-q">{f.q}</span>
            <span class="faq-icon">+</span>
          </button>
          <p class="faq-a" id={`faq-a-${i}`}>{f.a}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!;
      const icon = btn.querySelector('.faq-icon')!;
      const isOpen = item.classList.contains('open');

      document.querySelectorAll('.faq-item.open').forEach(el => {
        el.classList.remove('open');
        el.querySelector('.faq-icon')!.textContent = '+';
        el.querySelector('.faq-btn')!.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        item.classList.add('open');
        icon.textContent = '–';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
