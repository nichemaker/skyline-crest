---
const services = [
  { no: '01', title: 'Residential',           desc: "Builder floors, apartments and villas matched to how you actually live." },
  { no: '02', title: 'Commercial & Retail',   desc: "Offices, shops and pre-leased assets with assured-return potential." },
  { no: '03', title: 'Plots & Villas',        desc: "Freehold plots and independent villas across Gurugram's prime sectors." },
  { no: '04', title: 'Builder Floors',        desc: "Boutique low-rise living in DLF, Sushant Lok and beyond." },
  { no: '05', title: 'Investment Advisory',   desc: "Portfolio strategy, entry timing and exit planning — end to end." },
  { no: '06', title: 'Property Management',   desc: "Leasing, tenant vetting and upkeep while you stay hands-off." },
];
---
<section id="services">
  <div class="section-inner">
    <div data-reveal style="max-width:620px;margin-bottom:clamp(36px,5vw,60px);">
      <div class="section-eyebrow">
        <span class="section-eyebrow-line"></span>
        <span class="section-eyebrow-text">What we do</span>
      </div>
      <h2 class="section-h2">
        <span>Full-spectrum advisory,</span>
        across every asset class.
      </h2>
    </div>
    <div class="services-grid">
      {services.map(s => (
        <div class="service-card">
          <div class="service-no">{s.no}</div>
          <h3 class="service-title">{s.title}</h3>
          <p class="service-desc">{s.desc}</p>
          <a href="#contact" class="service-link">Learn more <span>→</span></a>
        </div>
      ))}
    </div>
  </div>
</section>
