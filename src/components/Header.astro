---
---
<header id="site-header">
  <a href="#home" class="header-logo">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round">
      <path d="M2 21 L8.5 7 L15 21"></path>
      <path d="M9.5 21 L16 11 L22 21"></path>
    </svg>
    <span class="header-logo-text">
      <span class="header-logo-name">SKYLINE CREST</span>
      <span class="header-logo-sub">R E A L T Y</span>
    </span>
  </a>

  <nav class="header-nav">
    <a href="#home">Home</a>
    <a href="#about">About</a>
    <span class="props-dropdown">
      Properties <span class="props-dropdown-arrow">▼</span>
      <div class="props-menu">
        <div class="props-menu-inner">
          <a href="#properties">Residential</a>
          <a href="#properties">Commercial</a>
          <a href="#properties">Plots &amp; Villas</a>
          <a href="#properties">Builder Floors</a>
        </div>
      </div>
    </span>
    <a href="#localities">Localities</a>
    <a href="#contact">Blog</a>
    <a href="#contact">Contact</a>
  </nav>

  <div class="header-actions">
    <button class="theme-btn" id="theme-toggle" title="Toggle theme" aria-label="Toggle theme">
      <span class="theme-icon"></span>
    </button>
    <a href="tel:+918800654747" class="header-call">Call</a>
    <a href="https://wa.me/918800654747" class="header-wa" rel="noopener noreferrer">WhatsApp</a>
  </div>

  <button class="hamburger-btn" id="hamburger" aria-label="Open menu">
    <span></span><span></span><span></span>
  </button>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu" role="dialog" aria-modal="true" aria-label="Navigation menu">
  <div class="mobile-menu-top">
    <span class="header-logo-name">SKYLINE CREST</span>
    <button class="mobile-menu-close" id="mobile-close" aria-label="Close menu">×</button>
  </div>
  <nav class="mobile-nav">
    <a href="#home">Home</a>
    <a href="#about">About</a>
    <a href="#properties">Properties</a>
    <a href="#localities">Localities</a>
    <a href="#contact">Contact</a>
  </nav>
  <div class="mobile-menu-footer">
    <button id="mobile-theme" class="mf-theme">Theme</button>
    <a href="tel:+918800654747">Call</a>
    <a href="https://wa.me/918800654747" class="mf-wa" rel="noopener noreferrer">WhatsApp</a>
  </div>
</div>
