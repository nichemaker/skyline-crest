<section id="about">
  <div class="section-inner">
    <div class="about-grid">
      <div class="about-img" data-reveal>
        <span class="about-img-label">image · advisor with clients</span>
        <div class="about-badge">
          <div class="about-badge-label">RERA Registered</div>
          <div class="about-badge-num">HRERA-GGM-2019-0427</div>
        </div>
      </div>
      <div data-reveal data-reveal-delay>
        <div class="section-eyebrow">
          <span class="section-eyebrow-line"></span>
          <span class="section-eyebrow-text">Why Skyline Crest</span>
        </div>
        <h2 class="section-h2">
          <span>A consultancy, not a portal —</span>
          built on transparency and local depth.
        </h2>
        <p style="margin:24px 0 0;font-size:16.5px;line-height:1.72;color:var(--ink-2);max-width:54ch;">
          We don't push inventory. We listen, study the micro-market, and bring you a shortlist worth your time. Eighteen years across Gurugram's corridors means we know which builder floor holds value, which sector is turning, and which deal to walk away from.
        </p>
        <div class="about-pillars">
          <div class="about-pillar">
            <div class="about-pillar-title">Client-first</div>
            <div class="about-pillar-desc">Your interests lead every recommendation.</div>
          </div>
          <div class="about-pillar">
            <div class="about-pillar-title">Local depth</div>
            <div class="about-pillar-desc">Sector-level pricing and absorption data.</div>
          </div>
          <div class="about-pillar">
            <div class="about-pillar-title">End-to-end</div>
            <div class="about-pillar-desc">From shortlist to registry and handover.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
