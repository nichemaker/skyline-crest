---
const localities = [
  { name: 'DLF Phases 1–5',       band: '₹3.5–9 Cr' },
  { name: 'Golf Course Road',      band: '₹4–12 Cr' },
  { name: 'Golf Course Extn.',     band: '₹2.5–6 Cr' },
  { name: 'Sohna Road',            band: '₹1.4–3.5 Cr' },
  { name: 'Dwarka Expressway',     band: '₹1.8–4.5 Cr' },
  { name: 'South City 1 & 2',     band: '₹2.2–5 Cr' },
  { name: 'Sushant Lok',          band: '₹2–6 Cr' },
  { name: 'Sectors 56–57',        band: '₹1.6–3.8 Cr' },
];
---
<section id="localities">
  <div class="section-inner">
    <div data-reveal style="display:flex;flex-wrap:wrap;justify-content:space-between;align-items:flex-end;gap:20px;margin-bottom:clamp(34px,4vw,56px);">
      <div style="max-width:560px;">
        <div class="section-eyebrow">
          <span class="section-eyebrow-line"></span>
          <span class="section-eyebrow-text">Browse by locality</span>
        </div>
        <h2 class="section-h2">
          <span>Gurgaon's prime corridors,</span>
          with indicative price bands.
        </h2>
      </div>
    </div>
    <div class="localities-grid">
      {localities.map(l => (
        <a href="#properties" class="locality-card">
          <div class="locality-bg"></div>
          <div class="locality-overlay"></div>
          <div class="locality-info">
            <div class="locality-name">{l.name}</div>
            <div class="locality-band">{l.band}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
